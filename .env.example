# Copie este arquivo para .env e preencha com os valores reais.
# O arquivo .env NUNCA deve ser commitado — já está no .gitignore.

# URL do Google Apps Script publicado como Web App
VITE_PROXY_URL=https://script.google.com/macros/s/SEU_ID_AQUI/exec

# Token secreto — deve ser igual à constante TOKEN em proxy/proxy.gs
VITE_PROXY_TOKEN=seu-token-secreto-aqui

# URL da API do PowerChef (Node.js + Cloudflare Tunnel)
# Em desenvolvimento: URL gerada pelo Cloudflare Tunnel
# Em produção: URL fixa quando tiver domínio próprio
VITE_POWERCHEF_API_URL=https://sua-url.trycloudflare.com
